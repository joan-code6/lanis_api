[Unit]
Description=Schulportal Hessen API (lanis_api)
After=network.target

[Service]
Type=simple
WorkingDirectory={{PROJECT_DIR}}
EnvironmentFile={{PROJECT_DIR}}/.env
ExecStart={{PYTHON_BIN}} -m uvicorn api.api:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
